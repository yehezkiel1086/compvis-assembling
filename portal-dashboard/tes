<?php

$serverName = "10.19.16.21";
$database   = "prod_control";
$username   = "sql_pre";
$password   = "User@eng1";

try {

$conn = new PDO(
"sqlsrv:Server=$serverName;Database=$database;Encrypt=no;TrustServerCertificate=yes",
$username,
$password
);

$conn->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);

}
catch(PDOException $e){
die("Connection failed: ".$e->getMessage());
}

$selected_date = isset($_GET['filter_date']) ? $_GET['filter_date'] : '';
$top_limit = isset($_GET['top_limit']) ? (int)$_GET['top_limit'] : 50;
$shift = isset($_GET['shift']) ? $_GET['shift'] : '';

$where = [];


if($selected_date != '' && $shift != ''){

    $next_day = date('Y-m-d', strtotime($selected_date . ' +1 day'));

    if($shift == "1"){
        $where[] = "created_at >= '$selected_date 07:30:00' 
                    AND created_at <= '$selected_date 16:29:59'";
    }

    elseif($shift == "2"){
        $where[] = "created_at >= '$selected_date 16:30:00' 
                    AND created_at <= DATEADD(MINUTE,29,DATEADD(DAY,1,'$selected_date'))";
    }

    elseif($shift == "3"){
        $where[] = "created_at BETWEEN '$next_day 00:30:00' AND '$next_day 07:29:59'";
    }

}
elseif($selected_date != ''){
    // kalau pilih tanggal saja (tanpa shift)
    $start = $selected_date . " 00:00:00";
    $end   = $selected_date . " 23:59:59";

    $where[] = "created_at BETWEEN '$start' AND '$end'";
}

$whereSQL = "";
if(count($where) > 0){
$whereSQL = "WHERE ".implode(" AND ", $where);
}

$count_query = "
SELECT COUNT(*) as total
FROM assy_vision
$whereSQL
";

$count_stmt = $conn->query($count_query);
$total_data = $count_stmt->fetch(PDO::FETCH_ASSOC)['total'];

$query = "
SELECT TOP $top_limit
CONVERT(VARCHAR,created_at,120) as created_at,
barcode,
jenis,
type_pole,
pole,
sticker,
type_battery,
emboss,
datecode,
status,
image_path
FROM assy_vision
$whereSQL
ORDER BY created_at DESC
";



$stmt = $conn->query($query);

if(!$stmt){
die(print_r($conn->errorInfo(),true));
}

$data = $stmt->fetchAll(PDO::FETCH_ASSOC);

?>

